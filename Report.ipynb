     ]
    }
   ],
   "source": [
    "path = \"data/historical_data.csv\"\n",
    "df = pd.read_csv(path)\n",
    "\n",
    "print(f\"{df.shape[0]} rader, {df.shape[1]} kolumner\")\n",
    "print(f\"\\nTarget-fördelning:\")\n",
